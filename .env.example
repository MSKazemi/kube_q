# kube-q environment variables
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.

# ── Connection ────────────────────────────────────────────────────────────────

# API server URL
# KUBE_Q_URL=http://localhost:8000

# API key — required only when the server has auth enabled.
# Leave blank if the server has no auth configured.
# KUBE_Q_API_KEY=

# ── Timeouts (seconds) ────────────────────────────────────────────────────────

# KUBE_Q_TIMEOUT=120
# KUBE_Q_HEALTH_TIMEOUT=5
# KUBE_Q_NAMESPACE_TIMEOUT=3
# KUBE_Q_STARTUP_RETRY_TIMEOUT=30   # only retries for transient errors (timeout/5xx); connection refused exits immediately
# KUBE_Q_STARTUP_RETRY_INTERVAL=5

# ── Model ─────────────────────────────────────────────────────────────────────

# Model name sent in each request. Override if your backend exposes a different
# model identifier (e.g. a versioned snapshot or an alternate model).
# KUBE_Q_MODEL=kubeintellect-v2

# ── Behaviour ─────────────────────────────────────────────────────────────────

# KUBE_Q_STREAM=true
# KUBE_Q_OUTPUT=rich          # rich | plain
# KUBE_Q_LOG_LEVEL=INFO       # DEBUG | INFO | WARNING | ERROR

# ── Display names ─────────────────────────────────────────────────────────────

# KUBE_Q_USER_NAME=You
# KUBE_Q_AGENT_NAME=kube-q

# ── Cost estimation ───────────────────────────────────────────────────────────

# Override per-1K-token rates (USD) for cost estimation in /tokens / /cost.
# Only needed if your backend uses a model not in the built-in table, or if
# you want to use your own negotiated pricing.
#
# Built-in rates (USD per 1K tokens):
#   Model                   Prompt    Completion
#   kubeintellect-v2        0.003     0.006
#   gpt-4o                  0.005     0.015
#   gpt-4o-mini             0.00015   0.0006
#   claude-sonnet-4-6       0.003     0.015
#
# KUBE_Q_COST_PER_1K_PROMPT=0.003
# KUBE_Q_COST_PER_1K_COMPLETION=0.006
